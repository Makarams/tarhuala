{
  "version": 2,
  "outputDirectory": "public",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, stale-while-revalidate=60" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/data/:path*",   "destination": "/data/:path*" },
    { "source": "/images/:path*", "destination": "/images/:path*" },
    { "source": "/css/:path*",    "destination": "/css/:path*" },
    { "source": "/js/:path*",     "destination": "/js/:path*" },
    { "source": "/novels",        "destination": "/novels.html" },
    { "source": "/novel",         "destination": "/novel.html" },
    { "source": "/chapter",       "destination": "/chapter.html" },
    { "source": "/about",         "destination": "/about.html" },
    { "source": "/chapters",      "destination": "/chapters.html" },
    { "source": "/analytics",     "destination": "/analytics.html" },
    { "source": "/(.*)",          "destination": "/index.html" }
  ]
}
