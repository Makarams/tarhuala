{
  "version": 2,
  "buildCommand": "node build.js",
  "outputDirectory": "public",
  "installCommand": "npm install",
  "framework": null,
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" },
        { "key": "Content-Type", "value": "image/svg+xml" }
      ]
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ]
}